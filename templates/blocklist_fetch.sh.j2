#!/bin/bash

FILES=(
abuse-nl.txt
ads-nl.txt
crypto-nl.txt
drugs-nl.txt
fraud-nl.txt
gambling-nl.txt
malware-nl.txt
phishing-nl.txt
piracy-nl.txt
ransomware-nl.txt
redirect-nl.txt
scam-nl.txt
tracking-nl.txt
)

mkdir lists
for i in "${FILES[@]}"; do
  wget -4 -O "lists/$i" "https://blocklistproject.github.io/Lists/alt-version/$i"
done

cat lists/*.txt |sort -n |uniq > blocklist.txt

chmod 644 blocklist.txt

