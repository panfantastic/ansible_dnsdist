#!/usr/bin/env python3
import lmdb

BLOCKLIST = "/etc/dnsdist/blocklist.txt"
LMDB_PATH = "/etc/dnsdist/blocklist.lmdb"
MAP_SIZE = 512 * 1024 * 1024

env = lmdb.open(LMDB_PATH, map_size=MAP_SIZE, subdir=True)

with env.begin(write=True) as txn:
    count = 0
    with open(BLOCKLIST) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            reversed_name = ".".join(reversed(line.rstrip(".").split(".")))
            txn.put(reversed_name.encode(), b"1")
            count += 1

print(f"Wrote {count} entries")
env.close()

